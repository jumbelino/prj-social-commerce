# Backend required
DATABASE_URL=postgresql+psycopg://social_commerce:social_commerce@localhost:5432/social_commerce
OIDC_JWKS_URL=http://localhost:8080/realms/social-commerce/protocol/openid-connect/certs

# Backend optional
OIDC_ISSUER=http://localhost:8080/realms/social-commerce
OIDC_AUDIENCE=social-commerce-backend
OIDC_CLOCK_SKEW_SECONDS=300
OIDC_JWKS_CACHE_TTL_SECONDS=300
FRONTEND_ORIGIN=http://localhost:3000
APP_NAME=social-commerce-backend

# Payments (required to call Mercado Pago endpoints)
MERCADO_PAGO_ACCESS_TOKEN=replace-with-dev-token
MERCADO_PAGO_WEBHOOK_SECRET=replace-with-dev-webhook-secret
MERCADO_PAGO_NOTIFICATION_URL=

# Shipping (required to call Melhor Envio quote endpoint)
MELHOR_ENVIO_BASE_URL=https://sandbox.melhorenvio.com.br
MELHOR_ENVIO_TOKEN=replace-with-dev-token
SHIPPING_ORIGIN_POSTAL_CODE=01018020

# MinIO (required for admin image upload)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=product-images
# Optional: public base URL used to build public object URLs
MINIO_PUBLIC_BASE_URL=http://localhost:9000/product-images
