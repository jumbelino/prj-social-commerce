# Postgres
POSTGRES_DB=social_commerce
POSTGRES_USER=social_commerce
POSTGRES_PASSWORD=social_commerce

# Backend
DATABASE_URL=postgresql+psycopg://social_commerce:social_commerce@localhost:5432/social_commerce
REDIS_URL=redis://localhost:6379/0
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=product-images
MINIO_PUBLIC_BASE_URL=http://localhost:9000/product-images

# Keycloak validation (backend)
OIDC_ISSUER=http://localhost:8080/realms/social-commerce
OIDC_AUDIENCE=realm-management
OIDC_JWKS_URL=http://localhost:8080/realms/social-commerce/protocol/openid-connect/certs
FRONTEND_ORIGIN=http://localhost:3000

# Keycloak (frontend)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
INTERNAL_API_BASE_URL=http://backend:8000
NEXT_PUBLIC_OIDC_AUTHORITY=http://localhost:8080/realms/social-commerce
OIDC_INTERNAL_AUTHORITY=http://keycloak:8080/realms/social-commerce
NEXT_PUBLIC_OIDC_CLIENT_ID=social-commerce-frontend

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-dev-only-secret
OIDC_CLIENT_SECRET=

# Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN=replace-with-dev-token
MERCADO_PAGO_WEBHOOK_SECRET=replace-with-dev-webhook-secret

# Melhor Envio
MELHOR_ENVIO_BASE_URL=https://sandbox.melhorenvio.com.br
MELHOR_ENVIO_TOKEN=replace-with-dev-token
SHIPPING_ORIGIN_POSTAL_CODE=01018020

# Keycloak bootstrap admin (dev only)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
