# Domínio público
DOMAIN=canoa.aurea.works

# Postgres
POSTGRES_DB=social_commerce
POSTGRES_USER=social_commerce
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=TROQUE_POR_SENHA_FORTE
# Senha inicial do usuário admin do app (temporária — será pedida troca no primeiro login)
ADMIN_INITIAL_PASSWORD=TROQUE_POR_SENHA_FORTE

# NextAuth
NEXTAUTH_SECRET=TROQUE_gere_com_openssl_rand_base64_32
NEXT_PUBLIC_OIDC_CLIENT_ID=social-commerce-frontend

# MinIO
MINIO_ACCESS_KEY=TROQUE_POR_CHAVE_FORTE
MINIO_SECRET_KEY=TROQUE_POR_SENHA_FORTE
MINIO_BUCKET=product-images

# MercadoPago
MERCADO_PAGO_MOCK=0
MERCADO_PAGO_CHECKOUT_MODE=sandbox
MERCADO_PAGO_ACCESS_TOKEN=SEU_ACCESS_TOKEN_MP
MERCADO_PAGO_WEBHOOK_SECRET=SEU_WEBHOOK_SECRET_MP

# Melhor Envio
MELHOR_ENVIO_BASE_URL=https://sandbox.melhorenvio.com.br
MELHOR_ENVIO_TOKEN=SEU_TOKEN_MELHOR_ENVIO
SHIPPING_ORIGIN_POSTAL_CODE=SEU_CEP_DE_ORIGEM
